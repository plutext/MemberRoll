{
  "realm": "memberroll",
  "enabled": true,
  "displayName": "MemberRoll",
  "registrationAllowed": true,
  "registrationEmailAsUsername": false,
  "verifyEmail": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "sslRequired": "external",
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full administrative access to the memberroll server"
      },
      {
        "name": "manager",
        "description": "Admin-granted role nobody may claim (grant via the admin panel)"
      },
      {
        "name": "member",
        "description": "Ordinary member (self-claimed)"
      },
      {
        "name": "other",
        "description": "Interested party (self-claimed)"
      }
    ]
  },
  "clients": [
    {
      "clientId": "web",
      "name": "memberroll web UI (user webapp + admin panel)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8080/*"
      ],
      "webOrigins": [
        "http://localhost:8080"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:8080/*"
      },
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [],
      "protocolMappers": [
        {
          "name": "memberroll-server audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "memberroll-server",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "claimed-role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "claimed_role",
            "claim.name": "claimed_role",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "role-verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "role_verified",
            "claim.name": "role_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "test-cli",
      "name": "Dev-only: password grant for verification scripts",
      "description": "Lets curl mint tokens for the baked-in test users. Not an app path; deploy.sh strips it from a production realm.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [],
      "webOrigins": [],
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": [],
      "protocolMappers": [
        {
          "name": "memberroll-server audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.custom.audience": "memberroll-server",
            "access.token.claim": "true",
            "id.token.claim": "false"
          }
        },
        {
          "name": "claimed-role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "claimed_role",
            "claim.name": "claimed_role",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        },
        {
          "name": "role-verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "role_verified",
            "claim.name": "role_verified",
            "jsonType.label": "boolean",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "test-cli-noaud",
      "name": "Dev-only: mints tokens WITHOUT the server audience",
      "description": "Exists solely so the verification matrix can prove the server rejects tokens for other services.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [],
      "webOrigins": [],
      "defaultClientScopes": [
        "basic",
        "profile",
        "email",
        "roles"
      ],
      "optionalClientScopes": []
    },
    {
      "clientId": "server-service",
      "name": "memberroll server service account",
      "description": "Lets the war reconcile claimed roles and back the admin panel's users section via the Keycloak admin REST API. Dev secret — deploy.sh rotates it for production.",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "secret": "server-service-dev-secret",
      "redirectUris": [],
      "webOrigins": [],
      "defaultClientScopes": [
        "basic",
        "roles"
      ],
      "optionalClientScopes": []
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "firstName": "Test",
      "lastName": "User",
      "email": "testuser@example.invalid",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "testuser",
          "temporary": false
        }
      ],
      "realmRoles": [
        "member"
      ]
    },
    {
      "username": "testviewer",
      "enabled": true,
      "firstName": "Test",
      "lastName": "Viewer",
      "email": "testviewer@example.invalid",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "testviewer",
          "temporary": false
        }
      ],
      "realmRoles": []
    },
    {
      "username": "testadmin",
      "enabled": true,
      "firstName": "Test",
      "lastName": "Admin",
      "email": "testadmin@example.invalid",
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "testadmin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin"
      ]
    },
    {
      "username": "service-account-server-service",
      "enabled": true,
      "serviceAccountClientId": "server-service",
      "clientRoles": {
        "realm-management": [
          "view-users",
          "manage-users",
          "view-realm"
        ]
      }
    }
  ],
  "components": {
    "org.keycloak.userprofile.UserProfileProvider": [
      {
        "providerId": "declarative-user-profile",
        "subComponents": {},
        "config": {
          "kc.user.profile.config": [
            "{\"attributes\": [{\"name\": \"username\", \"displayName\": \"${username}\", \"validations\": {\"length\": {\"min\": 3, \"max\": 255}, \"username-prohibited-characters\": {}, \"up-username-not-idn-homograph\": {}}, \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"multivalued\": false}, {\"name\": \"email\", \"displayName\": \"${email}\", \"validations\": {\"email\": {}, \"length\": {\"max\": 255}}, \"required\": {\"roles\": [\"user\"]}, \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"multivalued\": false}, {\"name\": \"firstName\", \"displayName\": \"${firstName}\", \"validations\": {\"length\": {\"max\": 255}, \"person-name-prohibited-characters\": {}}, \"required\": {\"roles\": [\"user\"]}, \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"multivalued\": false}, {\"name\": \"lastName\", \"displayName\": \"${lastName}\", \"validations\": {\"length\": {\"max\": 255}, \"person-name-prohibited-characters\": {}}, \"required\": {\"roles\": [\"user\"]}, \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"multivalued\": false}, {\"name\": \"claimed_role\", \"displayName\": \"I am a ...\", \"validations\": {\"options\": {\"options\": [\"member\", \"other\"]}}, \"annotations\": {\"inputOptionLabels\": {\"member\": \"Member\", \"other\": \"Other\"}, \"inputType\": \"select\"}, \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\", \"user\"]}, \"multivalued\": false}, {\"name\": \"role_verified\", \"displayName\": \"Role claim verified\", \"validations\": {\"options\": {\"options\": [\"true\", \"false\"]}}, \"permissions\": {\"view\": [\"admin\", \"user\"], \"edit\": [\"admin\"]}, \"multivalued\": false}], \"groups\": [{\"name\": \"user-metadata\", \"displayHeader\": \"User metadata\", \"displayDescription\": \"Attributes, which refer to user metadata\"}]}"
          ]
        }
      }
    ]
  }
}
